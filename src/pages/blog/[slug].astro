---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const { slug } = Astro.params;
const allPosts = await getCollection('blog');
const post = allPosts.find((p: CollectionEntry<'blog'>) => p.slug === slug);

if (!post || post.data.draft) return Astro.redirect('/blog');

const { Content } = await post.render();

const related = allPosts
  .filter((p: CollectionEntry<'blog'>) => p.slug !== slug && !p.data.draft)
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{post.data.title} — John Musans</title>
    <meta name="description" content={post.data.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Noto+Serif:wght@400&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="font-mono text-ink bg-paper-canvas antialiased">
    <!-- Nav -->
    <header class="sticky top-0 z-50 bg-paper-canvas/85 backdrop-blur-md border-b border-pale-stone/15">
      <div class="max-w-[1432px] mx-auto px-6 md:px-10">
        <div class="flex items-center justify-between py-5">
          <a href="/" class="font-display text-[22px] text-ink">John<span class="text-faint-text">.</span>M</a>
          <a href="/blog" class="inline-flex items-center gap-2 text-[14px] text-off-black hover:underline underline-offset-4">
            ← Blog
          </a>
        </div>
      </div>
    </header>

    <!-- Article hero -->
    <article class="max-w-[720px] mx-auto px-6 md:px-10 pt-16 pb-24">
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-8">
        {post.data.tags.map((tag: string) => (
          <span class="text-[12px] tracking-[0.05em] uppercase text-off-black border border-off-black/60 rounded-full px-3 py-1">{tag}</span>
        ))}
      </div>

      <!-- Title -->
      <h1 class="font-display text-[40px] md:text-[56px] text-ink leading-[1.05] tracking-[-0.02em] mb-6">
        {post.data.title}
      </h1>

      <!-- Meta -->
      <p class="text-[14px] text-faint-text mb-10">
        Publié le {post.data.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>

      <!-- Cover -->
      {post.data.cover && (
        <div class="w-full aspect-[16/9] rounded-[24px] overflow-hidden bg-atmosphere-wash mb-12">
          <img src={post.data.cover} alt={post.data.title} class="w-full h-full object-cover" />
        </div>
      )}

      <!-- Content -->
      <div class="
        [&_h2]:font-serif [&_h2]:text-[28px] [&_h2]:md:text-[32px] [&_h2]:text-ink [&_h2]:leading-[1.2] [&_h2]:tracking-[-0.02em] [&_h2]:mt-12 [&_h2]:mb-4
        [&_h3]:font-serif [&_h3]:text-[22px] [&_h3]:text-ink [&_h3]:leading-[1.2] [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:text-[17px] [&_p]:text-pale-stone [&_p]:leading-[1.7] [&_p]:mb-5
        [&_ul]:space-y-2 [&_ul]:mb-5 [&_ul]:pl-0 [&_li]:text-[17px] [&_li]:text-pale-stone [&_li]:leading-[1.6] [&_li]:flex [&_li]:gap-2 [&_li:before]:content-['—'] [&_li:before]:text-faint-text [&_li:before]:shrink-0
        [&_strong]:text-ink [&_strong]:font-medium
        [&_a]:text-ink [&_a]:underline [&_a]:underline-offset-4 [&_a:hover]:no-underline
        [&_blockquote]:border-l-2 [&_blockquote]:border-off-black/30 [&_blockquote]:pl-5 [&_blockquote]:italic [&_blockquote]:text-pale-stone
        [&_code]:font-mono [&_code]:text-[14px] [&_code]:bg-atmosphere-wash [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded-md
        [&_pre]:bg-off-black [&_pre]:text-paper-canvas [&_pre]:rounded-[16px] [&_pre]:p-6 [&_pre]:overflow-x-auto [&_pre]:mb-6
      ">
        <Content />
      </div>
    </article>

    <!-- Related posts -->
    {related.length > 0 && (
      <section class="max-w-[1432px] mx-auto px-6 md:px-10 pb-24">
        <div class="border-t border-pale-stone/20 pt-16">
          <p class="text-[12px] tracking-[0.05em] uppercase text-off-black mb-3">Lire aussi</p>
          <h2 class="font-display text-[28px] text-ink mb-10">Autres articles.</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            {related.map((p: CollectionEntry<'blog'>) => (
              <a href={`/blog/${p.slug}`} class="group block rounded-[32px] border border-pale-stone/20 hover:border-off-black p-5 transition-colors">
                {p.data.cover && (
                  <div class="aspect-[16/9] rounded-[20px] overflow-hidden bg-paper-canvas/60 mb-4">
                    <img src={p.data.cover} alt={p.data.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" />
                  </div>
                )}
                <h3 class="font-display text-[20px] text-ink mb-2 leading-[1.2]">{p.data.title}</h3>
                <p class="text-[14px] text-pale-stone mb-3">{p.data.description}</p>
                <span class="text-[12px] tracking-[0.05em] uppercase text-faint-text">
                  {p.data.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' })}
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer class="border-t border-pale-stone/20">
      <div class="max-w-[1432px] mx-auto px-6 md:px-10 py-10 flex flex-col sm:flex-row justify-between gap-4 text-[12px] tracking-[0.05em] uppercase text-faint-text">
        <p>© 2025 John Musans</p>
        <a href="/#contact" class="hover:text-ink">Me contacter →</a>
      </div>
    </footer>
  </body>
</html>
