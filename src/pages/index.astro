---
import '../styles/global.css';

const projects = [
	{ 
		id: 1, 
		title: 'Refonte E-commerce Luxe', 
		description: 'Redesign complet d\'une boutique en ligne haut de gamme',
		image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600',
		tags: ['UI Design', 'Figma', 'Prototyping'],
		link: '#'
	},
	{ 
		id: 2, 
		title: 'Dashboard SaaS', 
		description: 'Interface intuitive pour plateforme de gestion de projet',
		image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600',
		tags: ['UX Research', 'Design System', 'React'],
		link: '#'
	},
	{ 
		id: 3, 
		title: 'Application Mobile Banking', 
		description: 'Expérience utilisateur fluide pour app bancaire',
		image: 'https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?w=600',
		tags: ['Mobile UI', 'User Testing', 'Animation'],
		link: '#'
	},
	{ 
		id: 4, 
		title: 'Site Web Agence Créative', 
		description: 'Landing page moderne avec animations interactives',
		image: 'https://images.unsplash.com/photo-1467232004584-a241de8bcf5d?w=600',
		tags: ['Frontend', 'GSAP', 'Tailwind CSS'],
		link: '#'
	},
	{ 
		id: 5, 
		title: 'Design System', 
		description: 'Bibliothèque de composants réutilisables pour startup',
		image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=600',
		tags: ['Design Tokens', 'Storybook', 'Documentation'],
		link: '#'
	},
	{ 
		id: 6, 
		title: 'Portfolio Artistique', 
		description: 'Site immersif pour photographe professionnel',
		image: 'https://images.unsplash.com/photo-1561070791-2526d30994b5?w=600',
		tags: ['Visual Design', 'Next.js', 'Framer Motion'],
		link: '#'
	},
];

const skills = [
	{ category: 'Design', items: ['Figma', 'Adobe XD', 'Sketch', 'Photoshop'] },
	{ category: 'Frontend', items: ['React', 'Vue.js', 'TypeScript', 'Tailwind CSS'] },
	{ category: 'UI/UX', items: ['Prototyping', 'User Research', 'Design System', 'Wireframing'] },
	{ category: 'Animation', items: ['Framer Motion', 'GSAP', 'CSS Animations', 'Lottie'] },
];

const experiences = [
	{ 
		role: 'UI/UX Designer & Frontend Developer', 
		company: 'Design Studio', 
		period: '2023 - Présent',
		description: 'Conception d\'interfaces utilisateur et développement frontend pour clients premium'
	},
	{ 
		role: 'UI Designer', 
		company: 'Digital Agency', 
		period: '2021 - 2023',
		description: 'Création d\'expériences digitales innovantes et accessibles'
	},
	{ 
		role: 'Junior Designer', 
		company: 'Creative Lab', 
		period: '2019 - 2021',
		description: 'Design d\'interfaces et prototypage pour startups'
	},
];
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>John MUSANS - UI/UX Designer & Frontend Developer</title>
		<meta name="description" content="Designer créatif spécialisé en interfaces utilisateur et développement frontend" />
	</head>
	<body class="font-sans text-black bg-white antialiased">
		<!-- Header -->
		<header class="sticky top-0 z-50 bg-white border-b border-gray-200">
			<div class="max-w-7xl mx-auto px-8">
				<div class="flex items-center justify-between py-6">
					<div class="text-xl font-normal tracking-[0.1em] uppercase">John M.</div>
					<nav class="hidden md:flex gap-12">
						<a href="#projets" class="text-sm tracking-wider uppercase transition-opacity hover:opacity-50">Projets</a>
						<a href="#competences" class="text-sm tracking-wider uppercase transition-opacity hover:opacity-50">Compétences</a>
						<a href="#experience" class="text-sm tracking-wider uppercase transition-opacity hover:opacity-50">Expérience</a>
						<a href="#contact" class="text-sm tracking-wider uppercase transition-opacity hover:opacity-50">Contact</a>
					</nav>
					<div class="flex gap-8">
						<a href="https://github.com" target="_blank" class="hidden md:block text-xs tracking-wider uppercase transition-opacity hover:opacity-50">GitHub</a>
						<a href="https://linkedin.com" target="_blank" class="hidden md:block text-xs tracking-wider uppercase transition-opacity hover:opacity-50">LinkedIn</a>
						<a href="#contact" class="text-xs tracking-wider uppercase transition-opacity hover:opacity-50">CV</a>
					</div>
				</div>
			</div>
		</header>

		<!-- Hero Section -->
		<section class="py-40 text-center border-b border-gray-200">
			<div class="max-w-3xl mx-auto px-8">
				<p class="text-sm tracking-[0.2em] uppercase text-gray-600 mb-6">UI/UX Designer & Frontend Developer</p>
				<h1 class="text-6xl md:text-7xl font-light tracking-tight mb-6">Designer des Interfaces qui Inspirent</h1>
				<p class="text-lg text-gray-600 leading-relaxed mb-12">Je conçois et développe des expériences digitales élégantes, intuitives et centrées sur l'utilisateur.</p>
				<div class="flex gap-4 justify-center flex-wrap">
					<a href="#projets" class="inline-block px-12 py-4 bg-black text-white text-sm tracking-[0.1em] uppercase transition-opacity hover:opacity-80">Voir mes projets</a>
					<a href="#contact" class="inline-block px-12 py-4 border border-black text-black text-sm tracking-[0.1em] uppercase transition-all hover:bg-black hover:text-white">Me contacter</a>
				</div>
			</div>
		</section>

		<!-- About -->
		<section class="py-24 bg-gray-50">
			<div class="max-w-4xl mx-auto px-8">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
					<div>
						<h2 class="text-4xl font-light tracking-tight mb-6">À Propos</h2>
						<p class="text-base text-gray-600 leading-relaxed mb-4">
							Designer UI/UX passionné avec plus de 5 ans d'expérience dans la création d'interfaces élégantes et d'expériences utilisateur mémorables.
						</p>
						<p class="text-base text-gray-600 leading-relaxed mb-6">
							Je maîtrise l'ensemble du processus créatif, de la recherche utilisateur au design system, jusqu'au développement frontend avec React et Vue.js.
						</p>
						<div class="flex gap-4">
							<a href="#contact" class="text-sm tracking-wider uppercase transition-opacity hover:opacity-50">Me contacter →</a>
						</div>
					</div>
					<div class="aspect-square bg-gray-200 rounded-sm overflow-hidden">
						<img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=600" alt="Workspace" class="w-full h-full object-cover" />
					</div>
				</div>
			</div>
		</section>

		<!-- Skills -->
		<section class="py-24 border-b border-gray-200" id="competences">
			<div class="max-w-7xl mx-auto px-8">
				<h2 class="text-4xl font-light tracking-tight text-center mb-16">Compétences</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
					{skills.map((skill) => (
						<div>
							<h3 class="text-sm font-medium tracking-wider uppercase mb-4 pb-2 border-b border-gray-200">{skill.category}</h3>
							<ul class="space-y-2">
								{skill.items.map((item) => (
									<li class="text-sm text-gray-600">{item}</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Projects -->
		<section class="py-24" id="projets">
			<div class="max-w-7xl mx-auto px-8">
				<div class="text-center mb-16">
					<h2 class="text-4xl font-light tracking-tight mb-4">Projets Récents</h2>
					<p class="text-base text-gray-600">Une sélection de mes réalisations les plus significatives</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{projects.map((project) => (
						<article class="group cursor-pointer border border-gray-200 hover:border-black transition-colors">
							<div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
								<img src={project.image} alt={project.title} loading="lazy" class="w-full h-full object-cover transition-opacity group-hover:opacity-70" />
							</div>
							<div class="p-6">
								<h3 class="text-lg font-normal tracking-wide mb-2">{project.title}</h3>
								<p class="text-sm text-gray-600 mb-4 leading-relaxed">{project.description}</p>
								<div class="flex flex-wrap gap-2 mb-4">
									{project.tags.map((tag) => (
										<span class="text-xs tracking-wider uppercase text-gray-500 px-2 py-1 border border-gray-200">{tag}</span>
									))}
								</div>
								<a href={project.link} class="text-sm tracking-wider uppercase transition-opacity hover:opacity-50">Voir le projet →</a>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<!-- Experience -->
		<section class="py-24 bg-gray-50" id="experience">
			<div class="max-w-4xl mx-auto px-8">
				<h2 class="text-4xl font-light tracking-tight text-center mb-16">Expérience</h2>
				<div class="space-y-12">
					{experiences.map((exp) => (
						<div class="border-l-2 border-gray-300 pl-8 relative">
							<div class="absolute w-4 h-4 bg-black rounded-full -left-[9px] top-1"></div>
							<div class="flex flex-col md:flex-row justify-between items-start mb-2">
								<h3 class="text-lg font-normal tracking-wide">{exp.role}</h3>
								<span class="text-sm text-gray-600 tracking-wider uppercase">{exp.period}</span>
							</div>
							<p class="text-base font-medium text-gray-700 mb-2">{exp.company}</p>
							<p class="text-sm text-gray-600 leading-relaxed">{exp.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Stats -->
		<section class="py-24 bg-black text-white">
			<div class="max-w-7xl mx-auto px-8">
				<div class="grid grid-cols-2 lg:grid-cols-4 gap-12">
					<div class="text-center">
						<h3 class="text-5xl font-light tracking-tight mb-2">60+</h3>
						<p class="text-sm tracking-wider uppercase opacity-70">Designs Créés</p>
					</div>
					<div class="text-center">
						<h3 class="text-5xl font-light tracking-tight mb-2">40+</h3>
						<p class="text-sm tracking-wider uppercase opacity-70">Clients Ravis</p>
					</div>
					<div class="text-center">
						<h3 class="text-5xl font-light tracking-tight mb-2">5+</h3>
						<p class="text-sm tracking-wider uppercase opacity-70">Années d'Expérience</p>
					</div>
					<div class="text-center">
						<h3 class="text-5xl font-light tracking-tight mb-2">12+</h3>
						<p class="text-sm tracking-wider uppercase opacity-70">Design Systems</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Contact -->
		<section class="py-24 text-center" id="contact">
			<div class="max-w-2xl mx-auto px-8">
				<h2 class="text-4xl font-light tracking-tight mb-4">Travaillons Ensemble</h2>
				<p class="text-base text-gray-600 mb-8">Vous avez un projet en tête ? Discutons-en autour d'un café.</p>
				<form class="space-y-4 text-left mb-8">
					<div>
						<input type="text" placeholder="Votre nom" required class="w-full px-4 py-4 border border-gray-200 text-sm bg-white focus:outline-none focus:border-black" />
					</div>
					<div>
						<input type="email" placeholder="Votre email" required class="w-full px-4 py-4 border border-gray-200 text-sm bg-white focus:outline-none focus:border-black" />
					</div>
					<div>
						<textarea placeholder="Votre message" rows="6" required class="w-full px-4 py-4 border border-gray-200 text-sm bg-white focus:outline-none focus:border-black resize-none"></textarea>
					</div>
					<button type="submit" class="w-full px-12 py-4 bg-black text-white text-sm tracking-[0.1em] uppercase transition-opacity hover:opacity-80">Envoyer</button>
				</form>
				<div class="flex justify-center gap-8">
					<a href="mailto:contact@example.com" class="text-sm tracking-wider uppercase transition-opacity hover:opacity-50">Email</a>
					<a href="https://linkedin.com" target="_blank" class="text-sm tracking-wider uppercase transition-opacity hover:opacity-50">LinkedIn</a>
					<a href="https://github.com" target="_blank" class="text-sm tracking-wider uppercase transition-opacity hover:opacity-50">GitHub</a>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="border-t border-gray-200 py-12 bg-gray-50">
			<div class="max-w-7xl mx-auto px-8">
				<div class="flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
					<div>
						<p class="text-sm font-medium tracking-wider uppercase mb-2">John Doe</p>
						<p class="text-xs text-gray-600">UI/UX Designer & Frontend Developer basé à Paris</p>
					</div>
					<div class="flex gap-8">
						<a href="https://github.com" target="_blank" class="text-sm tracking-wider transition-opacity hover:opacity-50">GitHub</a>
						<a href="https://linkedin.com" target="_blank" class="text-sm tracking-wider transition-opacity hover:opacity-50">LinkedIn</a>
						<a href="https://twitter.com" target="_blank" class="text-sm tracking-wider transition-opacity hover:opacity-50">Twitter</a>
						<a href="mailto:contact@example.com" class="text-sm tracking-wider transition-opacity hover:opacity-50">Email</a>
					</div>
				</div>
				<div class="border-t border-gray-200 mt-8 pt-8 text-center">
					<p class="text-xs text-gray-600">© 2025 John Doe. Tous droits réservés. Conçu et développé avec passion.</p>
				</div>
			</div>
		</footer>
	</body>
</html>
