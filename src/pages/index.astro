---
import ThemeToggle from '../components/ThemeToggle.astro';
import '../styles/global.css';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const rawProjects = await getCollection('projects');
const projects = rawProjects
  .sort((a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) => a.data.order - b.data.order);

const rawExperiences = await getCollection('experiences');
const experiences = rawExperiences
  .sort((a: CollectionEntry<'experiences'>, b: CollectionEntry<'experiences'>) => a.data.order - b.data.order);

const rawSkills = await getCollection('skills');
const skills = rawSkills
  .sort((a: CollectionEntry<'skills'>, b: CollectionEntry<'skills'>) => a.data.order - b.data.order);

---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>John MUSANS — UI/UX Designer & Frontend Developer</title>
		<meta name="description" content="Designer créatif spécialisé en interfaces utilisateur et développement frontend" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Noto+Serif:wght@400&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
    <script is:inline>
      const _t = localStorage.getItem('theme');
      if (_t === 'dark' || (!_t && matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
	</head>
	<body class="font-mono text-ink bg-paper-canvas antialiased">
		<!-- Notification Bar (Monad: Ink bg, Paper Canvas text) -->
		<div class="bg-ink text-paper-canvas">
			<div class="max-w-[1432px] mx-auto px-6 md:px-10 py-3 flex flex-col sm:flex-row items-center justify-center gap-3 text-[14px]">
				<span class="opacity-90">Disponible pour de nouveaux projets — Q2 2026</span>
				<a href="#contact" class="inline-flex items-center gap-2 border border-paper-canvas/80 rounded-full px-4 py-1 hover:bg-paper-canvas hover:text-ink transition-colors">
					Discuter d'un projet
					<span aria-hidden="true">→</span>
				</a>
			</div>
		</div>

		<!-- Header / Navigation -->
		<header class="sticky top-0 z-50 bg-paper-canvas/85 backdrop-blur-md border-b border-pale-stone/15">
			<div class="max-w-[1432px] mx-auto px-6 md:px-10">
				<div class="flex items-center justify-between py-5">
					<a href="#" class="font-display text-[22px] text-ink">John<span class="text-faint-text">.</span>M</a>
					<nav class="hidden md:flex items-center gap-2 text-[16px] text-off-black">
						<a href="#projets" class="px-2.5 py-2 hover:underline underline-offset-4">Projets</a>
						<a href="#competences" class="px-2.5 py-2 hover:underline underline-offset-4">Compétences</a>
						<a href="#experience" class="px-2.5 py-2 hover:underline underline-offset-4">Expérience</a>
						<a href="#faq" class="px-2.5 py-2 hover:underline underline-offset-4">FAQ</a>
					</nav>
					<div class="flex items-center gap-3">
						<ThemeToggle />
						<a href="https://github.com/Johnmusans" target="_blank" rel="noopener" class="hidden md:inline text-[14px] text-off-black hover:underline underline-offset-4">GitHub</a>
						<a href="#contact" class="hidden md:inline-flex items-center gap-2 border border-off-black text-off-black rounded-full px-4 py-2 text-[14px] hover:bg-off-black hover:text-paper-canvas transition-colors">
							Me contacter <span aria-hidden="true">→</span>
						</a>
						<button id="menu-toggle" class="md:hidden flex flex-col justify-center gap-[5px] w-8 h-8" aria-label="Ouvrir le menu" aria-expanded="false">
							<span class="block w-full h-0.5 bg-ink origin-center transition-all duration-300"></span>
							<span class="block w-full h-0.5 bg-ink transition-all duration-300"></span>
							<span class="block w-full h-0.5 bg-ink origin-center transition-all duration-300"></span>
						</button>
					</div>
				</div>
			</div>
		</header>

		<!-- Mobile Menu Overlay -->
		<nav id="mobile-menu" class="fixed inset-0 z-40 bg-paper-canvas flex flex-col items-center justify-center gap-7 opacity-0 pointer-events-none" aria-hidden="true">
			<a href="#projets" class="font-display text-[36px] text-ink hover:text-faint-text transition-colors mobile-nav-link">Projets</a>
			<a href="#competences" class="font-display text-[36px] text-ink hover:text-faint-text transition-colors mobile-nav-link">Compétences</a>
			<a href="#experience" class="font-display text-[36px] text-ink hover:text-faint-text transition-colors mobile-nav-link">Expérience</a>
			<a href="#faq" class="font-display text-[36px] text-ink hover:text-faint-text transition-colors mobile-nav-link">FAQ</a>
			<a href="#contact" class="font-display text-[36px] text-ink hover:text-faint-text transition-colors mobile-nav-link">Contact</a>
		</nav>

		<!-- Hero Section -->
		<section class="relative overflow-hidden">
			<div class="relative max-w-[1432px] mx-auto px-6 md:px-10 pt-24 pb-32 md:pt-32 md:pb-40 text-center">
				<span data-animate class="inline-block border border-off-black/80 rounded-full px-3 py-1 text-[12px] tracking-[0.05em] uppercase text-off-black mb-8">UI/UX · Frontend</span>
				<h1 data-animate data-delay="1" class="font-display text-[32px] sm:text-[56px] md:text-[80px] leading-[1.05] tracking-[-0.02em] text-ink max-w-4xl mx-auto">
					Des interfaces claires,<br />pensées pour <em class="not-italic underline decoration-1 underline-offset-[10px] decoration-off-black/30">l'humain</em>.
				</h1>
				<p data-animate data-delay="2" class="mt-8 text-[16px] md:text-[18px] text-pale-stone max-w-xl mx-auto leading-[1.5]">
					Je conçois et développe des produits digitaux élégants, sobres et performants — au service de l'usage et de la marque.
				</p>
				<div data-animate data-delay="3" class="mt-10 flex flex-wrap gap-3 justify-center">
					<a href="#projets" class="inline-flex items-center gap-2 bg-off-black text-paper-canvas rounded-full px-5 py-3.5 text-[14px] hover:bg-ink transition-colors">
						Voir mes projets <span aria-hidden="true">→</span>
					</a>
					<a href="#contact" class="inline-flex items-center gap-2 border border-off-black text-off-black rounded-full px-5 py-3.5 text-[14px] hover:bg-off-black hover:text-paper-canvas transition-colors">
						Discuter
					</a>
		</section>

		<!-- About -->
		<section class="max-w-[1432px] mx-auto px-6 md:px-10 pb-24">
			<div data-animate class="bg-atmosphere-wash rounded-[40px] p-8 md:p-10 lg:p-14">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16 items-center">
					<div>
						<p class="text-[12px] tracking-[0.05em] uppercase text-off-black mb-4">À propos</p>
						<h2 class="font-display text-[32px] md:text-[40px] text-ink leading-[1.15] mb-6">
							5+ ans à designer<br />des produits qui durent.
						</h2>
						<p class="text-[16px] text-pale-stone leading-[1.5] mb-4">
							Designer UI/UX et développeur frontend, j'accompagne startups et studios de la recherche utilisateur jusqu'à l'implémentation en React, Vue et Tailwind.
						</p>
						<p class="text-[16px] text-pale-stone leading-[1.5] mb-8">
							Mon approche : ne garder que l'essentiel, hiérarchiser l'information et soigner chaque détail typographique.
						</p>
						<div class="flex flex-wrap items-center gap-5">
							<a href="#contact" class="inline-flex items-center gap-2 text-[14px] text-ink border-b border-ink/30 pb-0.5 hover:border-ink">
								Travaillons ensemble <span aria-hidden="true">→</span>
							</a>
							<a href="/john-musans-cv.pdf" download class="inline-flex items-center gap-2 text-[14px] text-off-black border-b border-off-black/30 pb-0.5 hover:border-off-black transition-colors">
								↓ Télécharger le CV
							</a>
						</div>
					</div>
					<div class="aspect-square rounded-[32px] overflow-hidden bg-paper-canvas/40">
						<img src="/john-1 (1).jpg" alt="Portrait de John Musans" class="w-full h-full object-cover" />
					</div>
				</div>
			</div>
		</section>

		<!-- Skills -->
		<section class="max-w-[1432px] mx-auto px-6 md:px-10 pb-24" id="competences">
			<div data-animate class="flex items-end justify-between mb-12 gap-6 flex-wrap">
				<div>
					<p class="text-[12px] tracking-[0.05em] uppercase text-off-black mb-3">Compétences</p>
					<h2 class="font-display text-[32px] md:text-[40px] text-ink max-w-xl">Une boîte à outils précise, mise au service du produit.</h2>
				</div>
				<p class="text-[14px] text-pale-stone max-w-sm">Du wireframe au déploiement, je couvre l'ensemble du cycle design ↔ code.</p>
			</div>
			<div data-animate data-delay="1" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
				{skills.map((skill: CollectionEntry<'skills'>) => (
					<div class="rounded-[32px] border border-pale-stone/20 p-6 hover:border-off-black transition-colors">
						<h3 class="text-[14px] font-medium uppercase tracking-[0.05em] text-ink mb-5">{skill.data.category}</h3>
						<ul class="space-y-2">
							{skill.data.items.map((item: string) => (
								<li class="text-[14px] text-pale-stone flex items-center gap-2">
									<span class="inline-block w-1 h-1 rounded-full bg-off-black"></span>
									{item}
								</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</section>

		<!-- Projects -->
		<section class="max-w-[1432px] mx-auto px-6 md:px-10 pb-24" id="projets">
			<div data-animate class="flex items-end justify-between mb-12 gap-6 flex-wrap">
				<div>
					<p class="text-[12px] tracking-[0.05em] uppercase text-off-black mb-3">Sélection</p>
					<h2 class="font-display text-[32px] md:text-[40px] text-ink max-w-xl">Quelques projets récents.</h2>
				</div>
				<a href="#contact" class="text-[14px] text-off-black border-b border-off-black/30 pb-0.5 hover:border-off-black">Voir tout →</a>
			</div>
			{projects.length > 0 && (
				<a data-animate data-delay="1" href={`/projets/${projects[0].slug}`}
				   class="group flex flex-col md:flex-row rounded-[32px] bg-atmosphere-wash overflow-hidden mb-5 hover:shadow-[0_16px_48px_rgba(0,0,0,0.08)] transition-shadow duration-300">
					<div class="md:w-[58%] aspect-[4/3] md:aspect-auto overflow-hidden">
						<img src={projects[0].data.image} alt={projects[0].data.title} loading="lazy"
						     class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" />
					</div>
					<div class="flex-1 flex flex-col justify-between p-8 md:p-10 lg:p-14">
						<div>
							<div class="flex flex-wrap gap-2 mb-6">
								{projects[0].data.tags.map((tag: string) => (
									<span class="text-[11px] tracking-[0.05em] uppercase text-off-black border border-off-black/50 rounded-full px-3 py-1">{tag}</span>
								))}
							</div>
							<h3 class="font-display text-[32px] md:text-[42px] text-ink leading-[1.08] mb-4">
								{projects[0].data.title}
							</h3>
							<p class="text-[15px] text-pale-stone leading-[1.6] max-w-sm">{projects[0].data.description}</p>
						</div>
						<div class="mt-8 inline-flex items-center gap-2 text-[14px] text-ink border-b border-ink/30 self-start pb-0.5 group-hover:border-ink transition-colors">
							Voir le projet <span aria-hidden="true">→</span>
						</div>
					</div>
				</a>
			)}
			<div data-animate data-delay="2" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
				{projects.slice(1).map((project: CollectionEntry<'projects'>) => (
					<article class="group rounded-[32px] p-5 border border-pale-stone/20 hover:border-off-black transition-colors">
						<div class="relative aspect-[4/3] overflow-hidden rounded-[20px] bg-paper-canvas/60">
							<img src={project.data.image} alt={project.data.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" />
						</div>
						<div class="pt-5 px-1">
							<h3 class="font-display text-[22px] text-ink mb-2">{project.data.title}</h3>
							<p class="text-[14px] text-pale-stone leading-[1.5] mb-4">{project.data.description}</p>
							<div class="flex flex-wrap gap-2 mb-5">
								{project.data.tags.map((tag: string) => (
									<span class="text-[12px] tracking-[0.05em] uppercase text-off-black border border-off-black/60 rounded-full px-3 py-1">{tag}</span>
								))}
							</div>
							<a href={`/projets/${project.slug}`} class="inline-flex items-center gap-2 text-[14px] text-ink border-b border-ink/30 pb-0.5 hover:border-ink">
								Voir le projet <span aria-hidden="true">→</span>
							</a>
						</div>
					</article>
				))}
			</div>
		</section>

		<!-- Experience timeline -->
		<section class="max-w-[1432px] mx-auto px-6 md:px-10 pb-24" id="experience">
			<div data-animate class="mb-12">
				<p class="text-[12px] tracking-[0.05em] uppercase text-off-black mb-3">Parcours</p>
				<h2 class="font-display text-[32px] md:text-[40px] text-ink max-w-xl">Expérience professionnelle.</h2>
			</div>
			<ol data-animate data-delay="1" class="relative border-l border-pale-stone/30 pl-8 space-y-10">
				{experiences.map((exp: CollectionEntry<'experiences'>) => (
					<li class="relative">
						<span class="absolute -left-[37px] top-1.5 w-3 h-3 rounded-full bg-off-black ring-4 ring-paper-canvas"></span>
						<div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 mb-2">
							<h3 class="font-display text-[24px] text-ink">{exp.data.role}</h3>
							<span class="text-[12px] tracking-[0.05em] uppercase text-faint-text">{exp.data.period}</span>
						</div>
						<p class="text-[14px] uppercase tracking-[0.05em] text-off-black mb-2">{exp.data.company}</p>
					</li>
				))}
			</ol>
		</section>

		<!-- Stats -->
		<section class="max-w-[1432px] mx-auto px-6 md:px-10 pb-24">
			<div data-animate class="bg-ink text-paper-canvas rounded-[40px] p-10 md:p-14">
				<div class="grid grid-cols-2 lg:grid-cols-4 gap-10">
					{[
						['60+', 'Designs livrés'],
						['30+', 'Clients satisfaits'],
						['5+', 'Années d\'expérience'],
						['10+', 'Design systems'],
					].map(([num, label]) => (
						<div>
							<h3 class="font-display text-[48px] md:text-[64px] leading-none mb-3">{num}</h3>
							<p class="text-[12px] tracking-[0.05em] uppercase text-paper-canvas/70">{label}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="max-w-[1024px] mx-auto px-6 md:px-10 pb-24" id="faq">
			<div data-animate class="mb-12 text-center">
				<p class="text-[12px] tracking-[0.05em] uppercase text-off-black mb-3">FAQ</p>
				<h2 class="font-display text-[32px] md:text-[40px] text-ink">Questions fréquentes.</h2>
			</div>
			<div data-animate data-delay="1" class="divide-y divide-pale-stone/30 border-t border-b border-pale-stone/30">
				{[
					{ q: 'Quels types de projets acceptes-tu ?', a: 'Sites marketing, applications web/SaaS, design systems et refontes UX. Je travaille principalement avec des startups et studios.' },
					{ q: 'Travailles-tu en remote ?', a: 'Oui — basé à Lubumbashi (RDC), je collabore quotidiennement avec des équipes en Europe et en Afrique.' },
					{ q: 'Quel est ton délai habituel ?', a: 'Une landing page : 1 à 2 semaines. Un produit complet : 4 à 8 semaines, selon la complexité.' },
					{ q: 'Quel est ton stack technique ?', a: 'Figma pour le design, React / Astro / Vue côté code, Tailwind CSS pour le style et Framer Motion / GSAP pour les animations.' },
				].map((item) => (
					<details class="group py-6">
						<summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
							<h3 class="font-display text-[20px] md:text-[24px] text-ink">{item.q}</h3>
							<span aria-hidden="true" class="shrink-0 mt-1 w-7 h-7 rounded-full border border-off-black flex items-center justify-center text-[14px] transition-transform group-open:rotate-45">+</span>
						</summary>
						<p class="mt-4 text-[16px] text-pale-stone leading-[1.5] max-w-3xl">{item.a}</p>
					</details>
				))}
			</div>
		</section>

		<!-- Contact -->
		<section class="max-w-[1432px] mx-auto px-6 md:px-10 pb-24" id="contact">
			<div class="relative overflow-hidden bg-atmosphere-wash rounded-[40px] p-8 md:p-14">
				<div class="pointer-events-none absolute -bottom-24 -right-24 w-[320px] h-[320px] rounded-full blur-3xl opacity-70 blob-amber"></div>
				<div data-animate class="relative grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16">
					<div>
						<p class="text-[12px] tracking-[0.05em] uppercase text-off-black mb-3">Contact</p>
						<h2 class="font-display text-[32px] md:text-[48px] text-ink leading-[1.1] mb-6">
							Travaillons<br />ensemble.
						</h2>
						<p class="text-[16px] text-pale-stone leading-[1.5] mb-8 max-w-md">
							Une idée, un produit à lancer, une refonte ? Écris-moi quelques mots — je réponds sous 24h.
						</p>
						<div class="space-y-2 text-[14px] text-off-black">
							<a href="mailto:johnmusansmk@gmail.com" class="block hover:underline underline-offset-4">johnmusansmk@gmail.com</a>
							<a href="https://www.linkedin.com/in/john-musans-93b6ba376" target="_blank" rel="noopener" class="block hover:underline underline-offset-4">LinkedIn →</a>
							<a href="https://github.com/Johnmusans" target="_blank" rel="noopener" class="block hover:underline underline-offset-4">GitHub →</a>
						</div>
					</div>
					<form id="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-3">
						<input type="hidden" name="_subject" value="Nouveau message — Portfolio John Musans" />
						<input type="text" name="name" placeholder="Votre nom" required class="w-full px-5 py-4 rounded-full bg-paper-canvas border border-pale-stone/20 text-[14px] text-ink placeholder:text-faint-text focus:outline-none focus:border-off-black" />
						<input type="email" name="email" placeholder="Votre email" required class="w-full px-5 py-4 rounded-full bg-paper-canvas border border-pale-stone/20 text-[14px] text-ink placeholder:text-faint-text focus:outline-none focus:border-off-black" />
						<textarea name="message" placeholder="Parlez-moi de votre projet…" rows="6" required class="w-full px-5 py-4 rounded-[28px] bg-paper-canvas border border-pale-stone/20 text-[14px] text-ink placeholder:text-faint-text focus:outline-none focus:border-off-black resize-none"></textarea>
						<input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
						<div id="form-success" class="hidden text-[14px] text-ink bg-paper-canvas/80 rounded-[20px] px-5 py-4 text-center">
							✓ Message envoyé ! Je vous réponds sous 24h.
						</div>
					<div id="form-error" class="hidden flex items-start gap-3 text-[14px] text-ink bg-paper-canvas/80 rounded-[20px] px-5 py-4">
						<span class="shrink-0 mt-0.5" aria-hidden="true">✕</span>
						<p id="form-error-text">Une erreur est survenue. Veuillez réessayer.</p>
					</div>
					<button type="submit" id="form-submit" class="w-full inline-flex items-center justify-center gap-2 bg-off-black text-paper-canvas rounded-full px-5 py-4 text-[14px] hover:bg-ink transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
						<span id="form-spinner" class="hidden w-4 h-4 rounded-full border-2 border-paper-canvas/30 border-t-paper-canvas animate-spin flex-shrink-0"></span>
						<span id="form-btn-text">Envoyer le message</span>
						<span id="form-btn-arrow" aria-hidden="true"> →</span>
					</button>
					</form>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="border-t border-pale-stone/20">
			<div class="max-w-[1432px] mx-auto px-6 md:px-10 py-12">
				<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
					<div>
						<p class="font-display text-[24px] text-ink mb-1">John Musans</p>
						<p class="text-[14px] text-pale-stone">UI/UX Designer & Frontend Developer · RD Congo</p>
					</div>
					<nav class="flex flex-wrap gap-x-6 gap-y-2 text-[14px] text-off-black">
						<a href="https://github.com/Johnmusans" target="_blank" rel="noopener" class="hover:underline underline-offset-4">GitHub</a>
						<a href="https://www.linkedin.com/in/john-musans-93b6ba376" target="_blank" rel="noopener" class="hover:underline underline-offset-4">LinkedIn</a>
						<a href="https://wa.me/" target="_blank" rel="noopener" class="hover:underline underline-offset-4">WhatsApp</a>
						<a href="mailto:johnmusansmk@gmail.com" class="hover:underline underline-offset-4">Email</a>
					</nav>
				</div>
				<div class="mt-10 pt-6 border-t border-pale-stone/15 flex flex-col sm:flex-row justify-between gap-3 text-[12px] tracking-[0.05em] uppercase text-faint-text">
					<p>© {new Date().getFullYear()} John Musans — Tous droits réservés.</p>
					<p>Conçu avec Astro · Tailwind v4</p>
				</div>
			</div>
		</footer>
		<script>
			// Scroll reveal
			const animEls = document.querySelectorAll('[data-animate]');
			const io = new IntersectionObserver((entries) => {
				entries.forEach(e => {
					if (e.isIntersecting) {
						e.target.classList.add('in-view');
						io.unobserve(e.target);
					}
				});
			}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
			animEls.forEach(el => io.observe(el));

			// Mobile menu
			const toggle = document.getElementById('menu-toggle');
			const mobileMenu = document.getElementById('mobile-menu');
			const lines = toggle?.querySelectorAll('span');
			let isOpen = false;

			function openMenu() {
				isOpen = true;
				toggle?.setAttribute('aria-expanded', 'true');
				mobileMenu?.classList.remove('opacity-0', 'pointer-events-none');
				mobileMenu?.setAttribute('aria-hidden', 'false');
				document.body.style.overflow = 'hidden';
				if (lines) {
					lines[0].style.transform = 'translateY(7px) rotate(45deg)';
					lines[1].style.opacity = '0';
					lines[2].style.transform = 'translateY(-7px) rotate(-45deg)';
				}
			}

			function closeMenu() {
				isOpen = false;
				toggle?.setAttribute('aria-expanded', 'false');
				mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
				mobileMenu?.setAttribute('aria-hidden', 'true');
				document.body.style.overflow = '';
				if (lines) {
					lines[0].style.transform = '';
					lines[1].style.opacity = '';
					lines[2].style.transform = '';
				}
			}

			toggle?.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
			mobileMenu?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
		</script>
	<script>
		const contactForm = document.getElementById('contact-form');
		const formSuccess = document.getElementById('form-success');
		const formError = document.getElementById('form-error');
		const formErrorText = document.getElementById('form-error-text');
		const formSubmit = document.getElementById('form-submit');
		const formSpinner = document.getElementById('form-spinner');
		const formBtnText = document.getElementById('form-btn-text');
		const formBtnArrow = document.getElementById('form-btn-arrow');

		function setLoading(loading) {
			if (loading) {
				formSpinner?.classList.remove('hidden');
				formBtnArrow?.classList.add('hidden');
				if (formBtnText) formBtnText.textContent = 'Envoi en cours…';
				if (formSubmit) formSubmit.disabled = true;
			} else {
				formSpinner?.classList.add('hidden');
				formBtnArrow?.classList.remove('hidden');
				if (formBtnText) formBtnText.textContent = 'Envoyer le message';
				if (formSubmit) formSubmit.disabled = false;
			}
		}

		function showError(msg) {
			if (formErrorText) formErrorText.textContent = msg;
			formError?.classList.remove('hidden');
			setTimeout(() => formError?.classList.add('hidden'), 6000);
		}

		contactForm?.addEventListener('submit', async (e) => {
			e.preventDefault();
			formError?.classList.add('hidden');
			setLoading(true);
			try {
				const res = await fetch(contactForm.action, {
					method: 'POST',
					body: new FormData(contactForm),
					headers: { Accept: 'application/json' },
				});
				if (res.ok) {
					contactForm.reset();
					if (formSuccess) formSuccess.classList.remove('hidden');
					if (formSubmit) formSubmit.style.display = 'none';
				} else {
					setLoading(false);
					showError('Une erreur est survenue. Vérifiez votre connexion et réessayez.');
				}
			} catch {
				setLoading(false);
				showError('Erreur réseau. Vérifiez votre connexion et réessayez.');
			}
		});
	</script>
	</body>
</html>
